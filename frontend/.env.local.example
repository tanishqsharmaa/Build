# ── Private (server-side only — NOT exposed to browser) ─────────────────────
# Supabase: Dashboard → Settings → API → Project URL
SUPABASE_URL=

# Supabase: Dashboard → Settings → API → service_role key (secret!)
SUPABASE_SERVICE_KEY=

# ── Client-accessible (VITE_ prefix = sent to browser by Vite) ──────────────
# Modal API base URL (from `modal serve` or `modal deploy` output)
VITE_API_URL=https://tanishqsharmaa--skillbridge-fastapi-app-dev.modal.run

# Supabase: Dashboard → Settings → API → Project URL (public, safe for client)
VITE_SUPABASE_URL=

# Supabase: Dashboard → Settings → API → anon/public key
VITE_SUPABASE_ANON_KEY=
